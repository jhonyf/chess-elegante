{
  "family": "chess-elegante",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::741403056818:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::741403056818:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "chess-elegante-app",
      "image": "741403056818.dkr.ecr.us-east-1.amazonaws.com/chess-elegante:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "FLASK_ENV",
          "value": "production"
        }
      ],
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:741403056818:secret:chess-elegante/DATABASE_URL"
        },
        {
          "name": "GOOGLE_CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:741403056818:secret:chess-elegante/GOOGLE_CLIENT_ID"
        },
        {
          "name": "GOOGLE_CLIENT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:741403056818:secret:chess-elegante/GOOGLE_CLIENT_SECRET"
        },
        {
          "name": "LICHESS_API_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:741403056818:secret:chess-elegante/LICHESS_API_TOKEN"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:741403056818:secret:chess-elegante/SECRET_KEY"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:741403056818:secret:chess-elegante/OPENAI_API_KEY"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/chess-elegante",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:5000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
